<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/parent_primary"
    android:padding="32dp">

    <!-- Premium Icon / Identity -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="96dp"
        android:layout_height="96dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@android:color/white"
        android:layout_marginBottom="24dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_secure"
            android:padding="20dp"
            app:tint="@color/parent_primary"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- App Name Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Linkly-Link"
        android:textColor="@android:color/white"
        android:textSize="36sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.05"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Parental Digital Protection Engine"
        android:textColor="#93C5FD"
        android:textSize="14sp"
        android:layout_marginTop="6dp"
        android:fontFamily="sans-serif-medium"/>

    <!-- Loading Bar Indicator -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:layout_width="140dp"
        android:layout_height="6dp"
        android:layout_marginTop="64dp"
        android:indeterminate="true"
        app:trackColor="#3B82F6"
        app:indicatorColor="@android:color/white"
        app:trackCornerRadius="3dp"/>

</LinearLayout>
