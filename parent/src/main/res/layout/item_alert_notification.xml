<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E2E8F0"
    app:cardBackgroundColor="@color/parent_card_bg"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- WhatsApp Style Circle Icon Badge with Dynamic Category Background -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCategoryIconBg"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#FEE2E2">
            
            <ImageView
                android:id="@+id/imgAlertCategory"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@android:drawable/stat_sys_warning"
                android:padding="12dp"
                app:tint="#EF4444"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Notification Description Core -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Child Protection Engine"
                    android:textColor="@color/parent_dark"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif"/>

                <TextView
                    android:id="@+id/textAlertTimestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12:45"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- Alert Alert Message Description -->
            <TextView
                android:id="@+id/textAlertMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠️ Warning: GPS Location was toggled OFF!"
                android:textColor="#334155"
                android:textSize="13sp"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- Status Dot (Red = Critical, Yellow = Warn, Green = Sync) -->
        <View
            android:id="@+id/alertStatusDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="#EF4444"
            android:layout_marginStart="12dp"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
