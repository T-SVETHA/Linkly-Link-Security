<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/child_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

    <!-- Active Shield Connection Indicator -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="32dp"
        android:background="#1F2937"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <View
            android:id="@+id/statusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="#EF4444"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/textSystemStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shield Unlinked"
            android:textColor="#E5E7EB"
            android:textSize="13sp"
            android:fontFamily="sans-serif-bold"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Linkly Node"
        android:textColor="@android:color/white"
        android:textSize="32sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-black"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Device Protection Companion Client"
        android:textColor="@color/text_muted"
        android:textSize="13sp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="36dp"
        android:fontFamily="sans-serif-medium"/>

    <!-- Main Dashboard Action Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="18dp"
        app:cardElevation="6dp"
        app:strokeWidth="1dp"
        app:strokeColor="#374151"
        app:cardBackgroundColor="@color/child_card_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp">

            <TextView
                android:id="@+id/textInstruction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter this pairing key in your parent app to initiate full security synchronization."
                android:textColor="#D1D5DB"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"/>

            <TextView
                android:id="@+id/textPairingCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="------"
                android:textColor="@android:color/white"
                android:textSize="44sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:fontFamily="monospace"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenerateCode"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Generate Safety Pairing Code"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/child_purple"
                app:cornerRadius="12dp"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewUsageStats"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="View App Screen Stats"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/child_pink"
                app:cornerRadius="12dp"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLaunchGame"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🎮 Launch Educational Quiz Game"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/child_green"
                app:cornerRadius="12dp"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ⏳ Screen Time Status Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="18dp"
        app:cardElevation="6dp"
        app:strokeWidth="1dp"
        app:strokeColor="#374151"
        app:cardBackgroundColor="@color/child_card_bg"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏳ Daily Screen Time Used"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textChildScreenTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 mins used out of 60 mins limit"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="12dp" />

            <!-- Progress Bar -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressChildScreenTime"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                app:trackThickness="8dp"
                app:trackCornerRadius="4dp"
                android:progress="0"
                app:trackColor="#1F2937"
                app:indicatorColor="#10B981" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>