<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/child_background"
    android:padding="28dp">

    <!-- Top Navigation Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🧠 Brain Quiz Challenge"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif-black"/>

    <TextView
        android:id="@+id/textQuestionProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Question 1 of 5"
        android:textColor="@color/text_muted"
        android:textSize="13sp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="24dp"
        android:fontFamily="sans-serif-medium"/>

    <!-- Linear Progress Indicator -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/quizProgress"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:progress="20"
        app:trackColor="#1F2937"
        app:indicatorColor="#10B981"
        app:trackCornerRadius="4dp"
        android:layout_marginBottom="32dp"/>

    <!-- Central Question Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="180dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#374151"
        app:cardBackgroundColor="@color/child_card_bg"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/textQuestionContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="What is the next number in the pattern: 2, 4, 8, 16, ?"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="24dp"
            android:lineSpacingExtra="4dp"
            android:fontFamily="sans-serif"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Multiple Choice Options Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Option A -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOptionA"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="20"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/child_card_bg"
            app:strokeWidth="1dp"
            app:strokeColor="#374151"
            app:cornerRadius="12dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- Option B -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOptionB"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="24"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/child_card_bg"
            app:strokeWidth="1dp"
            app:strokeColor="#374151"
            app:cornerRadius="12dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- Option C -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOptionC"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="32"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/child_card_bg"
            app:strokeWidth="1dp"
            app:strokeColor="#374151"
            app:cornerRadius="12dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- Option D -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOptionD"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="64"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/child_card_bg"
            app:strokeWidth="1dp"
            app:strokeColor="#374151"
            app:cornerRadius="12dp"
            android:textSize="15sp"
            android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>
