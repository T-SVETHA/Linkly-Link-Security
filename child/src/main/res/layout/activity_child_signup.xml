<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/child_background"
    android:padding="24dp">

    <!-- Header / Logo Area (Always Visible) -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="24dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/child_purple"
            android:layout_marginEnd="10dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@android:drawable/ic_secure"
                android:padding="8dp"
                app:tint="@android:color/white"/>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Linkly Child"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"/>
    </LinearLayout>

    <!-- Progress Indicator Walkthrough -->
    <LinearLayout
        android:id="@+id/layoutStepIndicators"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_below="@id/layoutHeader"
        android:layout_marginBottom="24dp">

        <!-- Step dots showing visual walkthrough stage -->
        <View
            android:id="@+id/dotStep1"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@color/child_purple"
            android:layout_marginEnd="8dp"/>
        <View
            android:id="@+id/dotStep2"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@color/child_card_bg"
            android:layout_marginEnd="8dp"/>
        <View
            android:id="@+id/dotStep3"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@color/child_card_bg"
            android:layout_marginEnd="8dp"/>
        <View
            android:id="@+id/dotStep4"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@color/child_card_bg"/>
    </LinearLayout>

    <!-- DYNAMIC CONTAINER FOR THE FLASH CARDS -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutStepIndicators"
        android:layout_above="@id/btnNextStep"
        android:layout_marginBottom="24dp">

        <!-- ================= CARD 1: SETUP PROFILE ================= -->
        <LinearLayout
            android:id="@+id/flashCardProfile"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Let's get started!"
                android:textColor="@android:color/white"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Please provide your name and age to begin setting up your safety monitoring companion app."
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="24dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="1dp"
                app:strokeColor="#374151"
                app:cardBackgroundColor="@color/child_card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Name Field -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Child Nickname / Name"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#4B5563"
                        app:cardBackgroundColor="@color/child_background"
                        android:layout_marginBottom="16dp">

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/editChildName"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="e.g. Alex"
                            android:textColorHint="#4B5563"
                            android:textColor="@android:color/white"
                            android:background="@android:color/transparent"
                            android:inputType="textPersonName"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:textSize="14sp"/>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Age Field -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Age (in Years)"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#4B5563"
                        app:cardBackgroundColor="@color/child_background">

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/editChildAge"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="e.g. 12"
                            android:textColorHint="#4B5563"
                            android:textColor="@android:color/white"
                            android:background="@android:color/transparent"
                            android:inputType="number"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:textSize="14sp"/>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ================= CARD 2: LOCATION FLASH CARD ================= -->
        <LinearLayout
            android:id="@+id/flashCardLocation"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Flash Card Background Canvas -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="#4C51BF"
                app:cardBackgroundColor="@color/child_card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center_horizontal">

                    <!-- Visual Center Graphic Badge -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="#E0F2FE"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="20dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@android:drawable/ic_menu_mylocation"
                            android:padding="20dp"
                            app:tint="#0284C7"/>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍 Real-Time Location Tracker"
                        android:textColor="@android:color/white"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Allows your parents to check your physical safety coordinates in real-time and alerts them automatically when you enter or leave designated geofence zones."
                        android:textColor="@color/text_muted"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginBottom="24dp"/>

                    <!-- State Badge Indicator -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#374151"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:layout_marginBottom="32dp">
                        
                        <View
                            android:id="@+id/viewLocationStatusIndicator"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@color/child_primary"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/textLocationStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ACCESS DISABLED"
                            android:textColor="@color/child_primary"
                            android:textSize="11sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGrantLocation"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Enable Location Services"
                        android:textColor="@android:color/white"
                        app:backgroundTint="@color/child_purple"
                        app:cornerRadius="12dp"
                        android:textStyle="bold"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ================= CARD 3: USAGE STATS FLASH CARD ================= -->
        <LinearLayout
            android:id="@+id/flashCardUsage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="#D53F8C"
                app:cardBackgroundColor="@color/child_card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center_horizontal">

                    <!-- Visual Center Graphic Badge -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="#FCE7F3"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="20dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@android:drawable/ic_menu_view"
                            android:padding="20dp"
                            app:tint="#D53F8C"/>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📊 App Activity Monitoring"
                        android:textColor="@android:color/white"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enables parent console synchronization of the currently opened foreground application so they are aware of digital distractions and can log screen time statistics."
                        android:textColor="@color/text_muted"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginBottom="24dp"/>

                    <!-- State Badge Indicator -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#374151"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:layout_marginBottom="32dp">
                        
                        <View
                            android:id="@+id/viewUsageStatusIndicator"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@color/child_primary"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/textUsageStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STATS DISABLED"
                            android:textColor="@color/child_primary"
                            android:textSize="11sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGrantUsage"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Enable App Activity Tracking"
                        android:textColor="@android:color/white"
                        app:backgroundTint="@color/child_pink"
                        app:cornerRadius="12dp"
                        android:textStyle="bold"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ================= CARD 4: OVERLAY SHIELD FLASH CARD ================= -->
        <LinearLayout
            android:id="@+id/flashCardOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="#48BB78"
                app:cardBackgroundColor="@color/child_card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center_horizontal">

                    <!-- Visual Center Graphic Badge -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="#D1FAE5"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="20dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@android:drawable/ic_lock_lock"
                            android:padding="20dp"
                            app:tint="#48BB78"/>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛡️ Parent Interception Overlay"
                        android:textColor="@android:color/white"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enables parent remote pause and offline digital boundary lockdown screens to overlay active apps, reminding you to disconnect and focus."
                        android:textColor="@color/text_muted"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginBottom="24dp"/>

                    <!-- State Badge Indicator -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#374151"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:layout_marginBottom="32dp">
                        
                        <View
                            android:id="@+id/viewOverlayStatusIndicator"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@color/child_primary"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/textOverlayStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OVERLAY DISABLED"
                            android:textColor="@color/child_primary"
                            android:textSize="11sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGrantOverlay"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Enable Lockdown Overlay"
                        android:textColor="@android:color/white"
                        app:backgroundTint="#48BB78"
                        app:cornerRadius="12dp"
                        android:textStyle="bold"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </FrameLayout>

    <!-- STEP NAVIGATION ACTION BUTTON (Always Sticky Bottom) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNextStep"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Continue Walkthrough"
        android:textColor="@android:color/white"
        app:backgroundTint="@color/child_purple"
        app:cornerRadius="14dp"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="12dp"/>

</RelativeLayout>
