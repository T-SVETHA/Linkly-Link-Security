<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/child_background"
    android:padding="32dp">

    <!-- Secure Lock Icon -->
    <ImageView
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:src="@android:drawable/ic_secure"
        android:layout_marginBottom="28dp"
        app:tint="@color/child_primary"/>

    <!-- Warning Labels -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Device Paused"
        android:textColor="@android:color/white"
        android:textSize="32sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-black"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="This device is temporarily locked by a parent. Please take a break and disconnect."
        android:textColor="@color/text_muted"
        android:textSize="15sp"
        android:gravity="center"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="48dp"
        android:fontFamily="sans-serif-medium"
        android:lineSpacingExtra="3dp"/>

    <!-- Passphrase Input Box (Material design style) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="220dp"
        android:layout_height="56dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="@color/child_dark_red"
        app:cardBackgroundColor="@color/child_card_bg"
        android:layout_marginBottom="24dp">

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/editPinCode"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hint="Enter PIN"
            android:textColorHint="@color/text_muted"
            android:textColor="@android:color/white"
            android:background="@android:color/transparent"
            android:inputType="numberPassword"
            android:maxLength="4"
            android:gravity="center"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Sleek Unlock Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUnlock"
        android:layout_width="220dp"
        android:layout_height="54dp"
        android:text="Unlock Device"
        android:textColor="@android:color/white"
        app:backgroundTint="@color/child_primary"
        app:cornerRadius="14dp"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif"/>

</LinearLayout>